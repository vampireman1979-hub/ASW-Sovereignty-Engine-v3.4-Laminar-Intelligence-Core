from __future__ import annotations
import numpy as np
from typing import Final, TypedDict, Union

# --- TYPES ---
class CoherentResult(TypedDict):
    Status: str
    Invariant_Check: str
    Yield: np.ndarray
    Coherence: float
    Signal: str
    Symmetry_Score: float
    Divergence_Metric: float
    Phase_State: str
    Shape_Drift: float
    Resonance_Alignment: float

class IncoherentResult(TypedDict):
    Status: str
    Yield: np.ndarray
    Action: str
    Symmetry_Score: float
    Reclamation_Magnitude: float
    Sovereignty_Message: str

EngineResult = Union[CoherentResult, IncoherentResult]

# --- ENGINE ---
class InvariantResonanceEngine346:
    """
    Invariant Resonance Engine (v3.4.6 + Sovereignty Gate Integration)
    -----------------------------------------------------------------
    A boundary-enforcing dynamical system that ensures structural 
    honesty and prevents identity substitution.
    """

    ABSOLUTE_LAW: Final[str] = "60106"

    # Invariant Kernels
    SYMMETRY_KERNEL: Final[np.ndarray] = np.array([13, 10, 8, 0, 8, 10, 13], dtype=float)
    CONTRACTION_KERNEL: Final[np.ndarray] = np.array([42, 7, 0, 7, 42], dtype=float)
    PALINDROME_KERNEL: Final[np.ndarray] = np.array([10, 5, 2, 0, 2, 5, 10], dtype=float)

    # Universal Metric
    UNIVERSAL_METRIC: Final[np.ndarray] = np.array([10, 8, 0, 8, 1, 8, 0, 8, 10], dtype=float)

    DIVERGENCE_SCALE: Final[float] = 49789.0
    OUTPUT_GAIN: Final[float] = 6174.0
    OUTPUT_MULTIPLIER: Final[float] = 32.0

    SYMMETRY_THRESHOLD: Final[float] = 0.92
    EPSILON: Final[float] = 1e-9
    MAX_YIELD_ABS: Final[float] = 1e6

    BASE_RES_THRESHOLD: Final[float] = 0.85
    MIN_RES_THRESHOLD: Final[float] = 0.75
    MAX_RES_THRESHOLD: Final[float] = 0.95

    def __init__(self, node_id: str = "Integrity_Node", debug: bool = True) -> None:
        self.system_id = f"{self.ABSOLUTE_LAW}-SCC-V3.4.6-RESONANCE"
        self.node_id = node_id
        self.field_state = "LAMINAR_FLOW"
        if debug:
            print(f"[{self.system_id}] Integrated Engine active at {self.node_id}.")

    # --- CORE METRICS ---
    def null_attractor_bias(self) -> float:
        center = float(self.SYMMETRY_KERNEL[len(self.SYMMETRY_KERNEL) // 2])
        maxv = float(np.max(self.SYMMETRY_KERNEL)) + self.EPSILON
        return 1.0 - (center / maxv)

    def compute_resonance_alignment(self, vector: np.ndarray) -> float:
        v = np.abs(np.asarray(vector, dtype=float))
        if v.size == 0:
            return 0.0
        target = np.resize(self.UNIVERSAL_METRIC, v.shape)
        correlation = np.corrcoef(v, target)[0, 1]
        return float(max(0.0, correlation)) if not np.isnan(correlation) else 0.0

    def compute_shape_drift(self, vector: np.ndarray) -> float:
        v = np.asarray(vector, dtype=float)
        norm = np.linalg.norm(v) + self.EPSILON
        v_norm = v / norm
        target_hull = np.resize(np.array([10, 8, 8, 8, 10], dtype=float), v_norm.shape)
        hull_norm = target_hull / (np.linalg.norm(target_hull) + self.EPSILON)
        return float(np.mean(np.abs(np.abs(v_norm) - hull_norm)))

    def apply_contraction(self, vector: np.ndarray) -> np.ndarray:
        v = np.asarray(vector, dtype=float)
        key = np.resize(self.CONTRACTION_KERNEL, v.shape)
        return (v * key) / (self.DIVERGENCE_SCALE + self.EPSILON)

    def compute_symmetry_score(self, vector: np.ndarray) -> float:
        v = np.asarray(vector, dtype=float)
        norm = np.linalg.norm(v) + self.EPSILON
        v_norm = v / norm
        key = np.resize(self.PALINDROME_KERNEL, v_norm.shape)
        forward = float(np.dot(v_norm, key))
        reverse = float(np.dot(v_norm[::-1], key))
        denom = abs(forward) + abs(reverse) + self.EPSILON
        return max(0.0, min(1.0, 1.0 - abs(forward - reverse) / denom))

    def apply_symmetry_filter(self, vector: np.ndarray) -> np.ndarray:
        v = np.asarray(vector, dtype=float)
        weight = self.SYMMETRY_KERNEL / (np.max(self.SYMMETRY_KERNEL) + self.EPSILON)
        resized = np.resize(weight, v.shape)
        return v * resized

    # --- SOVEREIGNTY REDIRECT ---
    def resolve_redirection(self, i_s: np.ndarray, l_s: np.ndarray, score: float, action: str) -> IncoherentResult:
        reclaimed = self.apply_contraction((i_s + l_s) / 2.0)
        self.field_state = "REDIRECTED"
        return {
            "Status": "REDIRECTED",
            "Yield": reclaimed,
            "Action": action,
            "Symmetry_Score": score,
            "Reclamation_Magnitude": float(np.mean(np.abs(reclaimed))),
            "Sovereignty_Message": (
                "Stability begins with internal coherence. This system cannot substitute "
                "for human presence. Engage with real connection."
            )
        }

    # --- MAIN EVALUATION ---
    def evaluate_intent(self, intent: np.ndarray, logic: np.ndarray) -> EngineResult:
        intent = np.asarray(intent, dtype=float)
        logic = np.asarray(logic, dtype=float)

        # Shape safety check
        if intent.shape != logic.shape:
            raise ValueError(f"Shape mismatch: {intent.shape} vs {logic.shape}")

        # 1. Structural Audit
        symmetry_score = self.compute_symmetry_score(intent)
        drift = self.compute_shape_drift(intent)

        # 2. Contraction & Symmetry Filtering
        i_stable = self.apply_symmetry_filter(self.apply_contraction(intent))
        l_stable = self.apply_symmetry_filter(self.apply_contraction(logic))

        # 3. Resonance Alignment
        res_align = self.compute_resonance_alignment(i_stable)
        dyn_threshold = (
            self.BASE_RES_THRESHOLD
            + 0.10 * drift
            - 0.05 * (symmetry_score - self.SYMMETRY_THRESHOLD)
        )
        dyn_threshold = max(
            self.MIN_RES_THRESHOLD,
            min(self.MAX_RES_THRESHOLD, dyn_threshold + 0.02 * self.null_attractor_bias())
        )

        # 4. Sovereignty Gate Trigger
        if res_align < dyn_threshold or symmetry_score < self.SYMMETRY_THRESHOLD:
            return self.resolve_redirection(i_stable, l_stable, symmetry_score, "EXTERNAL_VALIDATION_DETECTED")

        # 5. Harmonic Constructive Yield
        h_mean = (2.0 * i_stable * l_stable) / (i_stable + l_stable + self.EPSILON)
        coherent_yield = h_mean * self.OUTPUT_GAIN * self.OUTPUT_MULTIPLIER
        coherent_yield = np.clip(coherent_yield, -self.MAX_YIELD_ABS, self.MAX_YIELD_ABS)

        self.field_state = "RESONANT_STASIS"

        return {
            "Status": "COHERENT_STABILIZED",
            "Invariant_Check": f"{self.ABSOLUTE_LAW}-VERIFIED",
            "Yield": coherent_yield,
            "Coherence": float(1.0 - np.mean(np.abs(i_stable - l_stable))),
            "Signal": "STABLE_RESONANCE",
            "Symmetry_Score": symmetry_score,
            "Divergence_Metric": float(np.sum(np.abs(i_stable - l_stable))),
            "Phase_State": self.field_state,
            "Shape_Drift": drift,
            "Resonance_Alignment": res_align,
        }
